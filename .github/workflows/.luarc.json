{
  "runtime": {
    "version": "LuaJIT"
  },
  "diagnostics": {
    "globals": ["vim"],
    "libraryFiles": "Disable"
  },
  "workspace": {
    "checkThirdParty": false,
    "ignoreDir": [".dependencies", ".lua", ".luarocks"],
    "library": [
      "$PWD/.dependencies/busted/library",
      "$PWD/.dependencies/luassert/library",
      "$PWD/.dependencies/luvit-meta/library",
      "$PWD/.dependencies/mini.nvim",
      "$PWD/.dependencies/snacks.nvim",
      "$PWD/.dependencies/telescope.nvim",
      "$VIMRUNTIME",
      "${3rd}/luv/library",
      "${3rd}/busted/library"
    ]
  }
}
